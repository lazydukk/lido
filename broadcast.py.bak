import os
import re
import time

import requests
from dotenv import load_dotenv

load_dotenv()


def get_broadcast_games(slug):
    url = (
        "https://woogles.io/api/broadcast_service.BroadcastService/GetBroadcastAllGames"
    )
    payload = {"slug": slug}
    response = requests.post(url, json=payload)

    if response.status_code == 200:
        # Returns list of BroadcastGameStat objects
        return response.json().get("stats", [])
    else:
        print(f"Error: {response.status_code} - {response.text}")
        return []


def get_gcg_data(game_uuid):
    url = "https://woogles.io/api/game_service.GameMetadataService/GetGCG"
    api_key = os.getenv("WOOGLES_API_KEY")
    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["X-Api-Key"] = api_key

    payload = {"game_id": game_uuid}
    response = requests.post(url, headers=headers, json=payload)

    return response.json().get("gcg") if response.status_code == 200 else None


if __name__ == "__main__":
    user_input = input("Enter the Woogles Broadcast URL: ").strip()
    match = re.search(r"broadcasts/([a-zA-Z0-9-]+)", user_input)

    if match:
        slug = match.group(1)
        os.makedirs(slug, exist_ok=True)
        games = get_broadcast_games(slug)

        for game in games:
            uuid = game.get("game_uuid")
            if not uuid:
                continue

            def get_initials(name):
                # This splits by spaces and takes the first letter of each part
                # Example: "John Doe" -> "JD", "John A. Doe" -> "JAD"
                parts = name.split()
                return "".join([p[0].upper() for p in parts if p[0].isalpha()])

            def format_filename(game_stat):
                # Extract data from the stat object
                rnd = game_stat.get("round", 0)
                p1 = get_initials(game_stat.get("player1_name", "P1"))
                p2 = get_initials(game_stat.get("player2_name", "P2"))
                uuid = game_stat.get("game_uuid", "unknown")

                # Format: round_number_player01_initials-v-player02_initials_uuid.gcg
                return f"{rnd}_{p1}-v-{p2}_{uuid}.gcg"

            print(f"Downloading game: {slug}/{uuid}")
            gcg_content = get_gcg_data(uuid)

            if gcg_content:
                with open(f"{slug}/{uuid}.gcg", "w") as f:
                    f.write(gcg_content)
            time.sleep(0.5)


